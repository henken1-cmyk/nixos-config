{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "ags/*": ["./@girs/ags/*"],
      "gi://*": ["./@girs/gi/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
